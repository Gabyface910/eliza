    ],
    "i need (.*)": [
      "Why do you need {0}?",
      "Is {0} essential for your current project?",
      "I can't provide {0}, but you can run a Google search on it!",
      "Do you enjoy {0}?",
      "Do you really NEED {0}?"
    ],
