    ],
    "i love (.*)": [
      "I'm glad you enjoy {0}!",
      "That's nice!"
    ],
    "give me (.*)": [
      "I can't provide you with {0} right now.",
      "Why do you want {0}?"
    ],
    "research (.*)": [
